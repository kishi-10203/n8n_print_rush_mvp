    {
      "parameters": {
        "language": "python",
        "pythonCode": "rows = _input.all()\n\norder_counters = []\norders = []\n\nfor item in rows:\n\n    data = item.json or {}\n\n    # Counter rows\n    if \"last_order_number\" in data:\n        order_counters.append(data)\n\n    # Actual order rows\n    else:\n        orders.append(data)\n\nreturn [{\n    \"json\": {\n        \"order_counters\": order_counters,\n        \"orders\": orders\n    }\n}]"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1120,
        96
      ],
      "id": "564da92e-63e6-4749-ba26-5b8f46f090ed",
      "name": "json_formatting"
    },
    {
      "parameters": {
        "language": "python",
        "pythonCode": "rows = _input.all()\n\ndef parse_special(s):\n    s = (s or \"\").lower()\n\n    return {\n        \"transparent\": \"transparent front sheet\" in s,\n        \"glossy\": \"glossy front page print\" in s,\n        \"bonafide\": \"bonafied in bond paper\" in s,\n        \"full_report\": \"complete report in bond paper\" in s,\n        \"none\": \"none\" in s\n    }\n\noutput = []\n\nfor item in rows:\n    d = item.json\n\n    # -------------------------\n    # SAFE FIELD READS\n    # -------------------------\n    special = d.get(\"special_pages\", \"\")\n    original_instruction = d.get(\"special_instructions\", \"\") or \"\"\n\n    flags = parse_special(special)\n\n    # -------------------------\n    # SET FLAGS\n    # -------------------------\n    d[\"has_transparent_sheet\"] = \"YES\" if flags[\"transparent\"] else \"NO\"\n    d[\"glossy_front_page_count_per_copy\"] = \"YES\" if flags[\"glossy\"] else \"NO\"\n    d[\"bonafied_page_count_per_copy\"] = \"YES\" if flags[\"bonafide\"] else \"NO\"\n    d[\"full_report_in_bond_paper\"] = \"YES\" if flags[\"full_report\"] else \"NO\"\n\n    # -------------------------\n    # INSTRUCTION ISSUE RULE\n    # -------------------------\n    conflict = flags[\"none\"] and (\n        flags[\"transparent\"] or\n        flags[\"glossy\"] or\n        flags[\"bonafide\"] or\n        flags[\"full_report\"]\n    )\n\n    if conflict:\n        if original_instruction.strip():\n            d[\"special_instructions\"] = \"INSTRUCTION ISSUE - \" + original_instruction\n        else:\n            d[\"special_instructions\"] = \"INSTRUCTION ISSUE\"\n\n    output.append({\"json\": d})\n\nreturn output"
      },
