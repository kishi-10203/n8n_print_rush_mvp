    {
      "parameters": {
        "language": "python",
        "pythonCode": "rows = _input.all()\n\ncleaned = []\n\nfor item in rows:\n    data = item.json or {}\n\n    college_code = data.get(\"college_code\")\n    last_number = data.get(\"last_order_number\")\n\n    # strict validation\n    if not college_code or last_number is None:\n        continue\n\n    cleaned.append({\n        \"json\": {\n            \"college_code\": str(college_code).strip(),\n            \"last_order_number\": int(last_number)\n        }\n    })\n\nreturn cleaned"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        672,
        0
      ],
      "id": "d91c81ba-8444-49c6-ba5c-b01b63432fee",
      "name": "format order_counters"
    },
    {
      "parameters": {
        "language": "python",
        "pythonCode": "from datetime import datetime\n\ndata = _input.first().json\n\norders = data.get(\"orders\", [])\ncounter_rows = data.get(\"order_counters\", [])\n\n# -----------------------------\n# BUILD BASE COUNTERS\n# -----------------------------\nbase_counter = {\n    str(row.get(\"college_code\", \"\")).strip():\n    int(row.get(\"last_order_number\"))\n    for row in counter_rows\n    if row.get(\"college_code\")\n    and row.get(\"last_order_number\") is not None\n}\n\n# -----------------------------\n# PROCESS ORDERS\n# -----------------------------\nworking_counter = base_counter.copy()\n\nprocessed_orders = []\n\nfor order in orders:\n\n    code = str(order.get(\"college_code\", \"\")).strip()\n\n    if not code:\n        continue\n\n    # Increment counter\n    working_counter[code] = working_counter.get(code, 0) + 1\n\n    # Generate order ID\n    order[\"order_id\"] = f\"{code}-{working_counter[code]:03d}\"\n\n    processed_orders.append(order)\n\n# -----------------------------\n# GENERATE BATCH ID\n# -----------------------------\ntimestamp = datetime.now().strftime(\"%Y%m%d-%H%M%S\")\n\nbatch_id = f\"EXEC-{timestamp}-IST\"\n\n# -----------------------------\n# RETURN RESULT\n# -----------------------------\nreturn [{\n    \"json\": {\n        \"batch_id\": batch_id,\n        \"total_orders\": len(processed_orders),\n        \"base_counters\": base_counter,\n        \"updated_counters\": working_counter,\n        \"orders\": processed_orders\n    }\n}]"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
