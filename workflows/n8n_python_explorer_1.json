              "name": "late_night_order",
              "value": "={{\n(() => {\n\n  const raw = String($json.Timestamp || \"\");\n  if (!raw) return \"NO\";\n\n  // Match: 12/28/2025 3:20:49\n  const m = raw.match(/^(\\d{1,2})\\/(\\d{1,2})\\/(\\d{4})\\s+(\\d{1,2}):(\\d{2}):(\\d{2})$/);\n\n  if (!m) return \"NO\";\n\n  const hour = Number(m[4]);\n\n  // Night window: 10PM → 6AM\n  return (hour >= 22 || hour < 6) ? \"YES\" : \"NO\";\n\n})()\n}}",
